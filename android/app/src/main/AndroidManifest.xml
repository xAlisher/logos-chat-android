<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />
    <!-- QR intro-bundle scanner (#15). Camera is optional: the paste-bundle
         fallback is always reachable, so no required uses-feature. -->
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-feature android:name="android.hardware.camera" android:required="false" />
    <!-- Valid-scan haptic (RN Vibration API throws SecurityException without this) -->
    <uses-permission android:name="android.permission.VIBRATE" />
    <!-- ChatService (#25): the node keeps receiving with the app backgrounded. -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <application
      android:name=".MainApplication"
      android:label="@string/app_name"
      android:icon="@mipmap/ic_launcher"
      android:roundIcon="@mipmap/ic_launcher_round"
      android:allowBackup="false"
      android:theme="@style/AppTheme"
      android:usesCleartextTraffic="${usesCleartextTraffic}"
      android:supportsRtl="true">
      <activity
        android:name=".MainActivity"
        android:label="@string/app_name"
        android:configChanges="keyboard|keyboardHidden|orientation|screenLayout|screenSize|smallestScreenSize|uiMode"
        android:launchMode="singleTask"
        android:windowSoftInputMode="adjustResize"
        android:exported="true">
        <intent-filter>
            <action android:name="android.intent.action.MAIN" />
            <category android:name="android.intent.category.LAUNCHER" />
        </intent-filter>
      </activity>

      <!-- ProcessPhoenix relauncher (#59): runs in a SEPARATE process so it survives
           the main-process kill needed to swap the dual-binary .so variant, then
           reliably brings MainActivity back to the foreground (the AlarmManager path
           vanished on Samsung). Invisible + excluded from recents. -->
      <activity
        android:name=".PhoenixActivity"
        android:process=":phoenix"
        android:theme="@android:style/Theme.Translucent.NoTitleBar"
        android:excludeFromRecents="true"
        android:exported="false" />

      <!-- Owns the node + DB so messages keep arriving (and persisting) while the
           app is backgrounded or swiped away; START_STICKY brings it back. -->
      <service
        android:name=".ChatService"
        android:foregroundServiceType="dataSync"
        android:exported="false" />
    </application>
</manifest>
